# VoiceClaw Environment Variables
# Copy to .env and fill in your keys

# ── LLM (required) ────────────────────────────────────
# Single OpenRouter key — swap models without code changes
OPENROUTER_API_KEY=

# Model slug — any model available on OpenRouter
# Fast:        google/gemini-flash-1.5
# Quality:     anthropic/claude-sonnet-4-6
# Open source: mistralai/mistral-large
LLM_MODEL=anthropic/claude-sonnet-4-6

# ── Voice (required) ──────────────────────────────────
DEEPGRAM_API_KEY=        # STT — deepgram.com
CARTESIA_API_KEY=        # TTS — cartesia.ai

# ── Optional overrides ────────────────────────────────
# Override TTS voice ID (Cartesia voice UUID)
# CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091

# Log level (debug | info | warning | error)
LOG_LEVEL=info
