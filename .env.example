# VoiceClaw Environment Variables
# Copy to .env and fill in your keys

# ── Model (required) ──────────────────────────────────
# Single OpenRouter key — swap models without code changes
OPENROUTER_API_KEY=Key_placeholder

# Model slug — any model available on OpenRouter
# Fast: google/gemini-flash-1.5
# Quality: anthropic/claude-sonnet-4-5
# Open source: mistralai/mistral-large
OPENCLAW_MODEL=Key_placeholder

# ── Voice (required) ──────────────────────────────────
DEEPGRAM_API_KEY=Key_placeholder        # STT — deepgram.com
CARTESIA_API_KEY=Key_placeholder         # TTS — cartesia.ai

# ── Tool Layer (optional but recommended) ─────────────
COMPOSIO_API_KEY=Key_placeholder         # composio.dev — Meta MCP OAuth layer

# ── Advanced ──────────────────────────────────────────
# Override STT provider (deepgram | whisper | assemblyai)
STT_PROVIDER=Key_placeholder

# Override TTS provider (cartesia | elevenlabs | openai)
TTS_PROVIDER=Key_placeholder

# Log level (debug | info | warning | error)
LOG_LEVEL=info
